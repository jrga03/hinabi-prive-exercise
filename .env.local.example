# Google Gemini API key — required for the /api/ai/generate-tasks route.
# Read by `@ai-sdk/google`. Get a free key at https://aistudio.google.com.
GOOGLE_GENERATIVE_AI_API_KEY=

# Persistence backend. "local" uses localStorage (default). Reserved for a
# future "supabase" implementation that hasn't been built yet.
NEXT_PUBLIC_BACKEND=local
